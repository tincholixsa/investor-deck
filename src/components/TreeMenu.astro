// Helper to split the number and the text from the title
const formatTitle = (title: string) => {
  const match = title.match(/^([\d\.]+)\s*(.*)/);
  if (match) {
    return { number: match[1], text: match[2] };
  }
  return { number: '', text: title };
};

// Pre-process items beforehand so the Vite template renderer doesn't crash on function evaluation
const formattedMenuItems = menuItems.map(section => ({
  ...section,
  ...formatTitle(section.title),
  children: section.children.map(child => ({
    ...child,
    ...formatTitle(child.title)
  }))
}));
---

<nav class="tree-menu">
  <ul class="level-1">
    {formattedMenuItems.map(section => (
      <li class="menu-section">
        <a href={`#${section.id}`} class="menu-link category-link">
          {section.number && <span class="nav-number">{section.number}</span>}
          {section.text}
        </a>
        {section.children.length > 0 && (
          <ul class="level-2">
            {section.children.map(child => (
              <li>
                <a href={`#${child.id}`} class="menu-link sub-link">
                  {child.number && <span class="nav-number">{child.number}</span>}
                  {child.text}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</nav>

<script>
  // Simple ScrollSpy Implementation for Island
  document.addEventListener('DOMContentLoaded', () => {
    const links = document.querySelectorAll('.menu-link');
    const sections = Array.from(links).map(link => {
      const url = new URL(link.href);
      return document.getElementById(url.hash.substring(1));
    }).filter(Boolean);

    const intersectingIds = new Set();
    let isScrolling = false;
    let scrollTimeout;

    // Handle clicks to prevent observer from overriding the selected item during smooth scroll
    links.forEach(link => {
      link.addEventListener('click', () => {
        isScrolling = true;
        clearTimeout(scrollTimeout);
        
        links.forEach(l => l.classList.remove('active'));
        link.classList.add('active');

        // Force the content underline to activate instantly on click
        const targetId = new URL(link.href).hash.substring(1);
        const targetSec = document.getElementById(targetId);
        
        document.querySelectorAll('.is-underlined').forEach(el => el.classList.remove('is-underlined'));
        if (targetSec) {
          // If it's a sub-section div, the H3 is a direct child.
          // If it's a main section, the H2 is inside .paper-section-header
          const heading = targetSec.querySelector(':scope > h3, :scope > .paper-section-header > h2, :scope > .mdx-heading, :scope > .paper-section-header > .section-title');
          if (heading) heading.classList.add('is-underlined');
        }
        
        const parentList = link.closest('.level-2');
        if (parentList) {
          parentList.classList.add('expanded');
        }

        // Re-enable observer after estimated scroll duration
        scrollTimeout = setTimeout(() => {
          isScrolling = false;
        }, 800);
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          intersectingIds.add(entry.target.id);
        } else {
          intersectingIds.delete(entry.target.id);
        }
      });

      if (isScrolling) return;

      // Find the best intersecting section by checking its distance from the top header pad
      let activeSection = null;
      let minDistance = Infinity;

      sections.forEach(sec => {
        if (sec && intersectingIds.has(sec.id)) {
          const rect = sec.getBoundingClientRect();
          // The header offset is ~135px. Use <= so that specific child items 
          // overwrite their generic parent sections if they share the same 'top' coordinate.
          const distance = Math.abs(rect.top - 135);
          if (distance <= minDistance) {
            minDistance = distance;
            activeSection = sec;
          }
        }
      });

      if (activeSection) {
        document.querySelectorAll('.is-underlined').forEach(el => el.classList.remove('is-underlined'));
        const heading = activeSection.querySelector(':scope > h3, :scope > .paper-section-header > h2, :scope > .mdx-heading, :scope > .paper-section-header > .section-title');
        if (heading) heading.classList.add('is-underlined');

        links.forEach(link => {
          const url = new URL(link.href);
          if (url.hash === `#${activeSection.id}`) {
            link.classList.add('active');
            const parentList = link.closest('.level-2');
            if (parentList) {
              parentList.classList.add('expanded');
            }
          } else {
            link.classList.remove('active');
          }
        });
      }
    }, { rootMargin: '-135px 0px -40% 0px' });

    sections.forEach(sec => sec && observer.observe(sec));
  });
</script>



