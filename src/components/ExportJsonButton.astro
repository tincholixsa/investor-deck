---
---

<div class="export-selector">
  <button id="export-toggle" class="export-selector__trigger" aria-label="Exportar documento">
    <span class="export-selector__icon" style="display:flex; align-items:center;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
    </span>
    <span>Exportar</span>
    <span class="export-selector__arrow">▾</span>
  </button>
  <div id="export-dropdown" class="export-selector__dropdown">
    <a class="export-selector__item" href="/api/export-paper.json" target="_blank" rel="noopener noreferrer" data-astro-reload>
      <span class="export-selector__item-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg></span>
      JSON
    </a>
    <a class="export-selector__item export-selector__item--disabled" href="#" onclick="return false;">
      <span class="export-selector__item-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg></span>
      PDF <span class="export-selector__badge">Próximamente</span>
    </a>
    <a class="export-selector__item export-selector__item--disabled" href="#" onclick="return false;">
      <span class="export-selector__item-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg></span>
      PPTX <span class="export-selector__badge">Próximamente</span>
    </a>
    <a class="export-selector__item export-selector__item--disabled" href="#" onclick="return false;">
      <span class="export-selector__item-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg></span>
      Podcast Video <span class="export-selector__badge">Próximamente</span>
    </a>
    <a class="export-selector__item export-selector__item--disabled" href="#" onclick="return false;">
      <span class="export-selector__item-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"></path><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"></path></svg></span>
      Podcast Audio <span class="export-selector__badge">Próximamente</span>
    </a>
  </div>
</div>

<style>
  .export-selector {
    position: relative;
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }

  .export-selector__trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 12px;
    color: var(--text-secondary);
    font-size: 0.82rem;
    font-family: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    box-shadow: none;
  }

  .export-selector__trigger:hover {
    color: var(--revenue);
    border-color: var(--revenue);
    background: rgba(127, 76, 245, 0.05);
  }

  .export-selector__arrow {
    font-size: 11px;
    opacity: 0.6;
    transition: transform 0.2s ease;
    margin-left: -2px;
  }

  .export-selector.open .export-selector__arrow {
    transform: rotate(180deg);
  }

  .export-selector__dropdown {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    right: auto;
    transform: translateY(8px);
    min-width: 170px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 6px 0;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: 9999;
    text-align: left;
  }

  .export-selector.open .export-selector__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .export-selector__item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    transition: all 0.15s ease;
    cursor: pointer;
    line-height: 1.2;
  }

  .export-selector__item:hover {
    background: var(--bg-soft);
    color: var(--title);
  }

  .export-selector__item--disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  .export-selector__item-icon {
    font-size: 0.9rem;
    width: 20px;
    text-align: center;
  }

  .export-selector__badge {
    font-size: 0.65rem;
    background: var(--bg-soft);
    color: var(--text-secondary);
    padding: 1px 6px;
    border-radius: 8px;
    margin-left: auto;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const selector = document.querySelector('.export-selector');
    const toggle = document.getElementById('export-toggle');

    toggle?.addEventListener('click', (e) => {
      e.stopPropagation();
      selector?.classList.toggle('open');
    });

    document.addEventListener('click', () => {
      selector?.classList.remove('open');
    });
  });
</script>
