---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;

// Separate the numbering (e.g. "00.4", "10.") from the rest of the text.
const numberMatch = title.match(/^([\d\.]+)\s*(.*)/);
const titleNumber = numberMatch ? numberMatch[1] : '';
const titleText = numberMatch ? numberMatch[2] : title;
---

<section id={id} class="paper-section">
  <div class="paper-section-header">
    <h2 class="section-title">
      {titleNumber && <span class="title-number">{titleNumber}</span>}
      {titleText}
    </h2>
  </div>
  <div class="paper-section-content">
    <slot />
  </div>
</section>

<style>
  .paper-section {
    margin-bottom: var(--spacing-8);
  }

  .section-title {
    font-size: 2rem;
    color: var(--title);
    margin-bottom: var(--spacing-4);
    padding-bottom: var(--spacing-2);
    position: relative;
    display: inline-block;
  }

  .section-title::after {
    content: '';
    position: absolute;
    bottom: 0px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--revenue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease-out;
  }

  :global(.is-underlined.section-title)::after {
    transform: scaleX(1);
  }

  .title-number {
    font-size: 0.7em;
    opacity: 0.8;
    margin-right: var(--spacing-2);
    font-weight: 500;
  }
  
  .paper-section-content {
    /* Typographic refinements for body content */
    font-size: 1.05rem;
    line-height: 1.7;
  }
</style>
