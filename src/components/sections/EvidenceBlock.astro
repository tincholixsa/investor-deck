---
interface Props {
  type?: 'quote' | 'data' | 'case';
  title?: string;
}

const { type = 'data', title } = Astro.props;
---

<div class={`evidence-block type-${type}`}>
  {title && <h4 class="evidence-title">{title}</h4>}
  <div class="evidence-content">
    <slot />
  </div>
</div>

<style>
  .evidence-block {
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--spacing-4);
    margin: var(--spacing-4) 0;
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--revenue);
  }

  .evidence-title {
    margin-top: 0;
    margin-bottom: var(--spacing-2);
    font-size: 1.1rem;
    color: var(--text);
  }

  .evidence-content {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
  
  .type-quote {
    border-left-color: var(--growth);
    font-style: italic;
  }
</style>
